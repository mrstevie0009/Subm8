// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  email                 String?   @unique
  emailVerifiedAt       DateTime?
  emailVerifyLastSentAt DateTime?
  handle                String    @unique @db.VarChar(20)
  displayName           String    @db.VarChar(40)
  role                  Role
  avatarUrl             String?
  bannerUrl             String?
  websiteUrl            String?   @db.VarChar(255)
  bio                   String?   @db.VarChar(300)
  kinks                 String[]  @default([])
  location              String?
  nsfwDefault           Boolean   @default(false)
  ageVerifiedAt         DateTime?
  isDeactivated         Boolean   @default(false)
  isAdmin               Boolean   @default(false)
  country               String?   @db.VarChar(2)
  passwordHash          String?
  phone                 String?

  blocks    Block[] @relation("UserBlocks")
  blockedBy Block[] @relation("UserBlockedBy")

  // Autodrain (neu: Subscription-Model)
  autoDrainsAsDomme AutoDrainSubscription[] @relation("AutoDrainDomme")
  autoDrainsAsSub   AutoDrainSubscription[] @relation("AutoDrainSub")

  twoFactorEnabled        Boolean              @default(false)
  twoFactorType           String?
  twoFactorSecret         String?
  twoFactorTempSecret     String?
  passwordResetProtection Boolean              @default(false)
  passwordResetTokens     PasswordResetToken[] @relation("UserPasswordResetTokens")

  accounts                      Account[]
  Bookmark                      Bookmark[]
  Comment                       Comment[]
  Community                     Community[]
  CommunityMember               CommunityMember[]
  conversationsAsDomme          Conversation[]    @relation("domme")
  conversationsAsSub            Conversation[]    @relation("sub")
  followers                     Follow[]          @relation("followee")
  following                     Follow[]          @relation("follower")
  Like                          Like[]
  messages                      Message[]
  reads                         MessageRead[]
  Payment_Payment_payeeIdToUser Payment[]         @relation("Payment_payeeIdToUser")
  Payment_Payment_payerIdToUser Payment[]         @relation("Payment_payerIdToUser")
  Payout                        Payout[]
  Post                          Post[]
  sessions                      Session[]
  sentTips                      Tip[]             @relation("sentTips")
  receivedTips                  Tip[]             @relation("receivedTips")
  Wallet                        Wallet?

  // 🔗 Multi-Account Verknüpfungen (Gegenfelder zu AccountLink)
  ownerLinks  AccountLink[] @relation("OwnerLinks")
  linkedAsAlt AccountLink[] @relation("LinkedAsAlt")

  notificationSettings UserNotificationSettings?
  reportsMade          ContentReport[]
  conversationReports  ConversationReport[]      @relation("ConversationReportsByUser")

  // Gegenrelation für CommentLike
  commentLikes CommentLike[]

  // Offer-Editor
  offerTitle String? @db.Text
  offerText  String? @db.Text
  offerBgUrl String?
  offerBgDim Float?  @default(0)

  // genau ein angepinnter Post pro User (optional)
  pinnedPostId String? @unique
  pinnedPost   Post?   @relation("UserPinnedPost", fields: [pinnedPostId], references: [id], onDelete: SetNull)

  createdInvites     CommunityInvite[]    @relation("InviteCreatedBy")
  receivedInvites    CommunityInvite[]    @relation("InviteTarget")
  SmsCode            SmsCode[]
  WebAuthnCredential WebAuthnCredential[]

  smsChallenges SmsChallenge[]

  ageVerified Boolean   @default(false)
  dob         DateTime?
  veriffId    String? // letzte Veriff-Verification-ID
  verifiedAt  DateTime?

  verifiedByUserId String?
  verifiedBy       User?   @relation("UserVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  verifiedChildren User[]  @relation("UserVerifiedBy") // inverse Seite für einfache Abfragen

  isFirstAdopter Boolean   @default(false)
  premiumUntil   DateTime? // active premium if premiumUntil > now()

  conversationsCreated Conversation[] @relation("ConversationCreatedBy")

  conversationMemberships ConversationMember[] // NEU: Gruppenteilnahmen

  notificationSeenAsRecipient NotificationSeenCursor[] @relation("NotificationSeenRecipient")
  notificationSeenAsActor     NotificationSeenCursor[] @relation("NotificationSeenActor")

  // Payout method selection + extra payout destinations
  payoutMethod        PayoutMethod @default(STRIPE_CONNECT)
  payoutPaxumEmail    String?
  payoutCosmoWalletId String?

  //STRIPE
  stripeCustomerId       String?
  stripeDefaultPmId      String? // optional
  stripeConnectAccountId String? // nur für Dommes (Creator)
  stripeAccountId        String?         @unique
  payoutRequests         PayoutRequest[]
  stripeDetailsSubmitted Boolean         @default(false)
  stripePayoutsEnabled   Boolean         @default(false)
  stripeChargesEnabled   Boolean         @default(false)
  stripeOnboardingLastAt DateTime?

  emailVerificationCodes EmailVerificationCode[]
  stepUpChallenges       StepUpChallenge[]
  stepUpAttempts         StepUpAttempt[]

  @@index([verifiedByUserId])
  @@index([premiumUntil])
  @@index([stripeCustomerId])
  @@index([stripeConnectAccountId])
}

/// --- Brute-force / Login Throttle -----------------------------------------
/// Speichert Fehlversuche pro (ip, identifier) und erlaubt temp/permanent Blocks.
model LoginThrottle {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  lastAttempt DateTime @updatedAt

  ip         String
  identifier String // normalisierte E-Mail oder @handle (lowercase)
  fails      Int    @default(0)

  blockedUntil DateTime?
  permanent    Boolean   @default(false)
  note         String?

  @@unique([ip, identifier], name: "LoginThrottle_ip_identifier_unique")
  @@index([blockedUntil])
  @@index([permanent])
  @@index([ip, identifier])
}

model SmsChallenge {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   SmsChallengePurpose
  codeHash  String // hash(6-stelliger Code)
  expiresAt DateTime
  attempts  Int                 @default(0)
  createdAt DateTime            @default(now())
}

model SmsCode {
  id        String   @id @default(cuid())
  userId    String
  code      String // 6 digits
  purpose   String // e.g. "2FA_SETUP", "LOGIN"
  expiresAt DateTime
  attempts  Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique // base64url
  publicKey    String // base64url
  counter      Int      @default(0)
  transports   String? // JSON-Array als String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  token     String   @id @db.VarChar(128)
  userId    String
  user      User     @relation("UserPasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model AccountLink {
  id           String   @id @default(cuid())
  ownerId      String
  linkedUserId String
  createdAt    DateTime @default(now())

  // Benannte Relationen – passen zu den obigen Feldern im User
  owner  User @relation("OwnerLinks", fields: [ownerId], references: [id], onDelete: Cascade)
  linked User @relation("LinkedAsAlt", fields: [linkedUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, linkedUserId])
  @@index([ownerId])
  @@index([linkedUserId])
}

model Follow {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  followerId String
  followeeId String
  followee   User     @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)
  follower   User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followeeId])
  @@index([followerId])
}

model Conversation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  type      ConversationType @default(DM)
  title     String?
  avatarUrl String?

  createdById String?
  createdBy   User?   @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  dommeId       String?
  subId         String?
  openedByDomme Boolean @default(true)
  domme         User?   @relation("domme", fields: [dommeId], references: [id], onDelete: Cascade)
  sub           User?   @relation("sub", fields: [subId], references: [id], onDelete: Cascade)

  unreadForDomme Int @default(0)
  unreadForSub   Int @default(0)

  hiddenForDomme DateTime?
  hiddenForSub   DateTime?

  members       ConversationMember[]
  messages      Message[]
  tips          Tip[]
  lastMessageId String?              @unique
  lastMessageAt DateTime?

  reports ConversationReport[]

  @@unique([type, dommeId, subId], name: "Conversation_type_domme_sub_unique")
  @@index([dommeId])
  @@index([subId])
  @@index([createdById]) // (optional aber sinnvoll)
  @@index([updatedAt(sort: Desc)], name: "Conversation_updated_desc_idx")
  @@index([lastMessageAt(sort: Desc)], name: "Conversation_lastMessageAt_desc_idx")
  @@index([type, dommeId, hiddenForDomme], name: "Conversation_dm_domme_hidden_idx")
  @@index([type, subId, hiddenForSub], name: "Conversation_dm_sub_hidden_idx")
}

model ConversationMember {
  conversationId String
  userId         String

  // Rolle in der Gruppe (ADMIN/MEMBER)
  role ConversationMemberRole @default(MEMBER)

  // Unread je Mitglied (für GROUP maßgeblich)
  unreadCount Int @default(0)

  muted Boolean @default(false)

  // (Optional nützlich) Zeitstempel für "zuletzt gelesen"
  lastReadAt DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  conversationId String
  authorId       String
  text           String?       @db.VarChar(4000)
  mediaUrl       String?
  mediaType      String?
  seenAt         DateTime?
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reads          MessageRead[]

  @@index([conversationId, createdAt(sort: Desc)]) // „letzte Nachricht je Konvo“
  @@index([authorId, createdAt(sort: Desc)]) // eigene Nachrichten/Unread schneller
  @@index([conversationId, authorId]) // Unread-Filter (author != me)
  @@index([conversationId, createdAt(sort: Desc), id(sort: Desc)], name: "Message_conv_created_id_desc_idx")
}

model ConversationTypingState {
  conversationId String
  userId         String
  updatedAt      DateTime @default(now())

  @@id([conversationId, userId])
  @@index([updatedAt], name: "ConversationTypingState_updated_idx")
  @@map("ConversationTypingState") // exakter Tabellenname wie im Code
}

model MessageRead {
  messageId    String
  readerUserId String
  readAt       DateTime @default(now())
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  readerUser   User     @relation(fields: [readerUserId], references: [id], onDelete: Cascade)
  // (PK ist (messageId, readerUserId); für unsere Abfrage-Reihenfolge bringt obiger Index viel)

  @@id([messageId, readerUserId])
  // 🔑 Für „reads none where readerUserId = me“
  @@index([readerUserId, messageId])
}

model Tip {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  fromUserId     String
  toUserId       String
  amountCents    Int
  currency       String        @db.VarChar(3)
  methodRef      String?       @unique
  status         TipStatus     @default(PENDING)
  note           String?       @db.VarChar(200)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  from           User          @relation("sentTips", fields: [fromUserId], references: [id], onDelete: Cascade)
  to             User          @relation("receivedTips", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@index([conversationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model UploadedMedia {
  id        String   @id @default(cuid())
  postId    String
  url       String
  alt       String?
  type      String? // "image/png", "video/mp4" usw.
  createdAt DateTime @default(now())
  Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Post {
  id          String     @id @default(cuid())
  authorId    String
  text        String
  mediaUrl    String?
  mediaAlt    String?
  mediaType   String? // z.B. "image/png" oder "video/mp4"
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  communityId String?
  repostOfId  String?
  quoteOfId   String?
  nsfw        Boolean    @default(false)
  bookmarks   Bookmark[]
  Comment     Comment[]
  Like        Like[]
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Community   Community? @relation(fields: [communityId], references: [id])
  quoteOf     Post?      @relation("QuoteOf", fields: [quoteOfId], references: [id])
  quotes      Post[]     @relation("QuoteOf")
  repostOf    Post?      @relation("RepostOf", fields: [repostOfId], references: [id])
  reposts     Post[]     @relation("RepostOf")

  uploaded UploadedMedia[]

  // Gegenfeld zur "UserPinnedPost"-Relation
  pinnedBy User? @relation("UserPinnedPost")

  @@index([authorId, createdAt])
  @@index([communityId, createdAt])
  @@index([repostOfId])
  @@index([quoteOfId])
}

/**
 * ----------------- Threaded Comments + Likes -------------------
 */

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  parentId  String?
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Self-Relation (Parent -> Replies)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  likes CommentLike[]

  mediaUrl String?
  mediaAlt String?

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId, createdAt])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

/**
 * --------------------------------------------------------------------
 */

model Community {
  id              String              @id
  slug            String              @unique
  name            String
  description     String?
  createdById     String
  createdAt       DateTime            @default(now())
  bannerUrl       String?
  joinPolicy      CommunityJoinPolicy @default(OPEN)
  User            User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  CommunityMember CommunityMember[]
  Post            Post[]
  invites         CommunityInvite[]
}

model CommunityMember {
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  Community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
}

model CommunityInvite {
  id String @id @default(cuid())

  // Beziehungen
  communityId String
  community   Community @relation(fields: [communityId], references: [id])

  createdById String
  createdBy   User   @relation("InviteCreatedBy", fields: [createdById], references: [id])

  // Für DIRECT-Einladungen (nur dieser/diese User darf annehmen)
  targetUserId String?
  targetUser   User?   @relation("InviteTarget", fields: [targetUserId], references: [id])

  // Meta
  type  InviteType
  token String     @unique
  note  String?

  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId])
  @@index([targetUserId])
}

/**
 * --------- Ledger (bestehend) ---------
 */

model Ledger {
  id          String          @id
  paymentId   String?
  entryType   LedgerEntryType
  account     LedgerAccount
  amountCents Int
  currency    String          @default("EUR")
  createdAt   DateTime        @default(now())
  Payment     Payment?        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

/**
 * --------- Payment (erweitert) ---------
 */

model Payment {
  id                    String        @id
  payerId               String
  payeeId               String
  amountGrossCents      Int
  amountNetToDommeCents Int
  platformFeeCents      Int
  processorFeeCents     Int           @default(0)
  vatAmountCents        Int           @default(0)
  currency              String        @default("EUR")
  status                PaymentStatus
  externalRef           String? // = stripe payment_intent id
  paymentProvider       String?       @default("Segpay")
  buyerCountry          String?       @db.VarChar(2)
  buyerIp               String?
  cardBin               String?       @db.VarChar(8)
  metadataJson          Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  stripeChargeId        String?

  Ledger          Ledger[]
  evidences       BuyerEvidence[]
  vatEntries      VatLedger[]
  platformRevenue PlatformRevenue?
  processorFees   ProcessorFeeLedger[]

  stripeTransferId String? @unique

  payoutRequestId String?
  payoutRequest   PayoutRequest? @relation(fields: [payoutRequestId], references: [id])

  User_Payment_payeeIdToUser User @relation("Payment_payeeIdToUser", fields: [payeeId], references: [id], onDelete: Cascade)
  User_Payment_payerIdToUser User @relation("Payment_payerIdToUser", fields: [payerId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([payerId])
  @@index([payeeId])
  @@index([payoutRequestId])
}

model StepUpChallenge {
  tokenHash  String    @id
  userId     String
  verifiedAt DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model StepUpAttempt {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum FeePayer {
  USER
  PLATFORM
}

model StripeEvent {
  id        String   @id // evt_...
  type      String
  livemode  Boolean  @default(false)
  account   String? // Connected Account ID (event.account) falls vorhanden
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([account])
}

model PayoutRequest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountCents Int
  currency    String @default("EUR")

  method      PayoutMethod
  destination String // paxum email / cosmo wallet / stripe acct id

  requestedCents Int
  feeCents       Int @default(0)
  payoutCents    Int

  feePayer FeePayer @default(USER)

  status PayoutStatus @default(REQUESTED)

  createdAt    DateTime  @default(now())
  processedAt  DateTime?
  failedReason String?

  stripeTransferId   String? @unique
  stripePayoutId     String? @unique
  stripePayoutStatus String?

  payments Payment[] @relation()

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/**
 * --------- Payout / Wallet ----------
 */

model Payout {
  id             String       @id
  userId         String
  amountCents    Int
  currency       String       @default("EUR")
  status         PayoutStatus
  method         String
  destinationRef String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  userId       String   @id
  balanceCents Int      @default(0)
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  email     String // normalisierte Email (lowercase)
  codeHash  String // sha256(code)
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

/**
 * ---------- Evidence & Finance Ledgers ----------
 */

// ---- Chats ----
enum ConversationType {
  DM
  GROUP
}

enum ConversationMemberRole {
  ADMIN
  MEMBER
}

enum EvidenceType {
  IP_GEO
  CARD_BIN
  BILLING
  USER_DECLARED
}

model BuyerEvidence {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  paymentId String
  payment   Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type      EvidenceType
  country   String?      @db.VarChar(2)
  source    String?
  value     String?

  @@index([paymentId])
}

model VatLedger {
  id             String   @id @default(cuid())
  paymentId      String
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  country        String?  @db.VarChar(2)
  rate           Int
  vatAmountCents Int
  status         String   @default("open")
  createdAt      DateTime @default(now())

  @@index([paymentId])
  @@index([status])
}

model PlatformRevenue {
  id               String   @id @default(cuid())
  paymentId        String   @unique
  payment          Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  grossFeeCents    Int
  providerFeeCents Int
  netRevenueCents  Int
  currency         String   @default("EUR")
  createdAt        DateTime @default(now())
}

model ProcessorFeeLedger {
  id          String   @id @default(cuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  provider    String
  amountCents Int
  currency    String   @default("EUR")
  createdAt   DateTime @default(now())

  @@index([paymentId])
}

/**
 * ---------- Reports / Notifications ----------
 */

enum ReportTargetType {
  POST
  USER
}

model ContentReport {
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  targetType     ReportTargetType
  targetId       String
  reporterUserId String
  reason         String?
  resolvedAt     DateTime?

  reporterUser User @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([resolvedAt])
}

model ConversationReport {
  id             String   @id @default(cuid())
  conversationId String
  reporterId     String
  reason         String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  reporter     User         @relation("ConversationReportsByUser", fields: [reporterId], references: [id])

  @@index([conversationId, createdAt])
}

model UserNotificationSettings {
  userId               String   @id
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushEnabled          Boolean  @default(true)
  dmMessages           Boolean  @default(true)
  dmReactions          Boolean  @default(true)
  mentions             Boolean  @default(true)
  comments             Boolean  @default(true)
  likes                Boolean  @default(true)
  newFollowers         Boolean  @default(true)
  photoTags            Boolean  @default(true)
  emailMessages        Boolean  @default(false)
  emailDigest          Boolean  @default(false)
  muteNotFollowing     Boolean  @default(false)
  muteNotFollowers     Boolean  @default(false)
  muteNewAccounts      Boolean  @default(false)
  muteNoAvatar         Boolean  @default(false)
  requireEmailVerified Boolean  @default(false)
  requirePhoneVerified Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model NotificationSeenCursor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Der Empfänger, der Notifications anschaut (du)
  recipientId String
  recipient   User   @relation("NotificationSeenRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  // Der Actor, dessen Events aggregiert werden (der Liker)
  actorId String
  actor   User   @relation("NotificationSeenActor", fields: [actorId], references: [id], onDelete: Cascade)

  // Welche Aggregation/Cursor-Art (z.B. "LIKE_POST", später evtl. "LIKE_COMMENT", "FOLLOW", etc.)
  kind NotificationCursorKind

  // Alles <= seenUntil gilt als "gesehen"
  seenUntil DateTime @default(dbgenerated("'1970-01-01T00:00:00.000Z'::timestamptz"))

  @@unique([recipientId, actorId, kind], name: "NotificationSeenCursor_unique")
  @@index([recipientId, kind, seenUntil])
  @@index([actorId])
}

enum NotificationCursorKind {
  LIKE_POST
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId, blockerId], name: "Block_blocked_idx")
}

/**
 * -------------------- Autodrain (neu) --------------------
 */

model AutoDrainSubscription {
  id           String           @id @default(cuid())
  dommeId      String
  subId        String
  amountCents  Int
  currency     String           @db.VarChar(8)
  cadence      AutoDrainCadence
  active       Boolean          @default(true)
  nextChargeAt DateTime
  lastChargeAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  domme   User              @relation("AutoDrainDomme", fields: [dommeId], references: [id], onDelete: Cascade)
  sub     User              @relation("AutoDrainSub", fields: [subId], references: [id], onDelete: Cascade)
  charges AutoDrainCharge[]

  stripeSubscriptionId String?
  stripeCustomerId     String?
  stripeStatus         String?

  @@index([subId, active, nextChargeAt])
  @@index([dommeId, subId, active])
}

model AutoDrainCharge {
  id             String                @id @default(cuid())
  subscriptionId String
  at             DateTime              @default(now())
  amountCents    Int
  currency       String                @db.VarChar(8)
  status         AutoDrainChargeStatus @default(PENDING)
  receiptId      String?
  error          String?

  subscription AutoDrainSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, at])
}

